{
  "name": "opencode-claude-max-proxy",
  "version": "1.12.0",
  "description": "Use your Claude Max subscription with OpenCode via proxy server",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "claude-max-proxy": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/server.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "./bin/claude-proxy-supervisor.sh",
    "proxy": "./bin/claude-proxy-supervisor.sh",
    "build": "rm -rf dist && bun build bin/cli.ts src/proxy/server.ts --outdir dist --target node --splitting --external @anthropic-ai/claude-agent-sdk --entry-naming '[name].js'",
    "postbuild": "node --check dist/cli.js && node --check dist/server.js",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "proxy:direct": "bun run ./bin/cli.ts",
    "maintain": "nsp review-upstream"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.80",
    "@hono/node-server": "^1.19.11",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "glob": "^13.0.0",
    "hono": "^4.11.4",
    "openai": "^6.32.0",
    "p-queue": "^8.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2"
  },
  "files": [
    "dist/",
    "bin/",
    "src/proxy/",
    "src/providers/",
    "src/mcpTools.ts",
    "src/logger.ts",
    "README.md",
    "Dockerfile",
    "docker-compose.yml"
  ],
  "keywords": [
    "opencode",
    "opencode-ai",
    "opencode-plugin",
    "claude",
    "claude-max",
    "claude-code",
    "anthropic",
    "ai-coding",
    "ai-assistant",
    "proxy",
    "claude-agent-sdk",
    "llm",
    "coding-assistant"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rynfar/opencode-claude-max-proxy.git"
  },
  "homepage": "https://github.com/rynfar/opencode-claude-max-proxy#readme",
  "bugs": {
    "url": "https://github.com/rynfar/opencode-claude-max-proxy/issues"
  },
  "author": "rynfar",
  "license": "MIT",
  "private": false,
  "packageManager": "bun@1.3.11"
}
